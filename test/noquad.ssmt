logic UFLIRA

type Point = (Real, Real)

Cross := fn (a, b, c)
	(c.1 - b.1) * (a.2 - b.2) - (c.2 - b.2) * (a.1 - b.1)

IsColinear := fn (a, b, c) Cross(a, b, c) = 0

IsConvex := fn (a, b, c) Cross(a, b, c) > 0

IsConvexQuad := fn (a, b, c, d) {
	IsConvex(a, b, c)
	IsConvex(b, c, d)
	IsConvex(c, d, a)
	IsConvex(d, a, b)
}

IsConvexPentagon := fn (a, b, c, d, e) {
	IsConvex(a, b, c)
	IsConvex(b, c, d)
	IsConvex(c, d, e)
	IsConvex(d, e, a)
	IsConvex(e, a, b)
}

// default : Real

// for i on [1, 4] weak {
// 	p_i : Point
// 	p_i = new Point(x_i, y_i)
// 	show p_i
// }

// IsConvexQuad(p_1, p_2, p_3, p_4)

getPoint : Int -> Point

default : Real

for i on [1, 5] {
	getPoint(i) = new Point(x_i, y_i)
	show x_i
	show y_i
}

for i_1, i_2, i_3 on [1, 5]
	(distinct j on [1, 3] of i_j) => ~IsColinear(
		getPoint(i_1), getPoint(i_2), getPoint(i_3)
	)

for n_1, n_2, n_3, n_4, n_5 : Int
	{
		distinct i on [1, 5] of n_i
		for i on [1, 5] {
			1 <= n_i
			n_i <= 5
		}
	} => {
		for i on [1, 5] p_i := getPoint(n_i)
		~IsConvexQuad(p_1, p_2, p_3, p_4)
		// ~IsConvexPentagon(p_1, p_2, p_3, p_4, p_5)
	}