{
	"$schema": "./schema.json",
	"name": "Super SMT",
	"patterns": [
		{
			"include": "#comments"
		}, {
			"include": "#keywords"
		}, {
			"include": "#numbers"
		}, {
			"include": "#identifiers"
		}
	],
	"repository": {
		"comments": {
			"patterns": [{
				"name": "comment.line",
				"match": "\\/\\/.*"
			}]
		},
		"keywords": {
			"patterns": [{
				"name": "keyword.operator",
				"match": "\\b(distinct|sum|show)\\b"
			}, {
				"name": "storage.type",
				"match": "->|:=|:|\\b(Int|Bool|Real)\\b|type|default|fn|prop|weak"
			}, {
				"name": "constant.language.boolean",
				"match": "\\b(true|false)\\b"
			}, {
				"name": "keyword.operator.arithmetic",
				"match": "-|\\^|\\+|\\*|%|\\/|~|\\b(or|and)\\b|=>"
			}, {
				"name": "keyword.operator.comparison",
				"match": "!=|=|<|>|<=|>="
			}, {
				"name": "keyword.operator.new",
				"match": "\\bnew\\b"
			}, {
				"name": "keyword.control",
				"match": "\\b(for|on|of|to|logic|print)\\b"
			}, {
				"name": "punctuation.separator.comma",
				"match": "[_,.]"
			}]
		},
		"numbers": {
			"name": "constant.numeric",
			"match": "\\d+"
		},
		"identifiers": {
			"patterns": [{
				"name": "entity.name.function",
				"match": "(?<!\\bto\\s*)[^\\W_]+(?=\\s*(\\(|:=\\s*fn\\b|:.*?->))"
			}, {
				"name": "variable.name",
				"match": "[^\\W_]+"
			}]
		}
	},
	"scopeName": "source.ssmt"
}