logic UFLIRA

// f(n) = 2^n - 2 + 1

type Point = (Real, Real)

Cross := fn (a, b, c)
	(c.1 - b.1) * (a.2 - b.2) - (c.2 - b.2) * (a.1 - b.1)

IsColinear := fn (a, b, c) Cross(a, b, c) = 0

IsConvex := fn (a, b, c) Cross(a, b, c) > 0

IsConvexQuad := fn (a, b, c, d) {
	IsConvex(a, b, c)
	IsConvex(b, c, d)
	IsConvex(c, d, a)
	IsConvex(d, a, b)
}

getPoint : Int -> Point

default : Real

for i on [1, 5] {
	getPoint(i) = new Point(x_i, y_i)
	show x_i
	show y_i
}

for i_1, i_2, i_3 on [1, 5]
	(distinct j on [1, 3] of i_j) => ~IsColinear(
		getPoint(i_1), getPoint(i_2), getPoint(i_3)
	)

Check := fn (a, b, c, d) {
	~IsConvexQuad(getPoint(a), getPoint(b), getPoint(c), getPoint(d))
}

CheckWithStart := fn (k_0, k_1, k_2, k_3) {
	for i_1, i_2, i_3 on [1, 3]
		(distinct j on [1, 3] of i_j) => {
			Check(k_0, k_(i_1), k_(i_2), k_(i_3))
		}
}

for i_1, i_2, i_3, i_4 on [1, 5]
	(i_1 < i_2 < i_3 < i_4) => {
		CheckWithStart(i_1, i_2, i_3, i_4)
	}